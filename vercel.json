{
  "rewrites": [
    {
      "source": "/",
      "destination": "/series_library.html"
    }
  ],
  "headers": [
    {
      "source": "/series_library_data.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/series_library_details.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
