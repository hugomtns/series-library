{
  "name": "series-library",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "migrate": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/rebuild_catalog_and_db.ps1",
    "update": "node scripts/update_library.js",
    "export": "node scripts/export_public_catalog.js",
    "refresh:action-seasons": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/refresh_open_series_seasons.ps1 -Category Action -SkipExisting",
    "refresh:comedy-seasons": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/refresh_open_series_seasons.ps1 -Category Comedy -SkipExisting",
    "trends": "node scripts/report_season_rating_trends.js",
    "posters:report": "node scripts/report_poster_delivery.js",
    "serve": "node series_library_server.js",
    "deploy:check": "node scripts/check_deploy_ready.js",
    "server:check": "node scripts/check_local_server.js",
    "schema:check": "node scripts/validate_public_json_schema.js",
    "plex:probe": "node scripts/plex_probe.js",
    "plex:sync": "node scripts/plex_sync.js",
    "plex:sync:apply": "node scripts/plex_sync.js --apply",
    "test:browser": "node scripts/browser_regression_check.js",
    "test:migrate": "node scripts/test_migrate_null_seasons.js",
    "test:update-pipeline": "node scripts/test_update_pipeline.js",
    "test:plex": "node scripts/test_plex_probe.js",
    "test:plex-sync": "node scripts/test_plex_sync.js",
    "test:state": "node scripts/test_series_state_store.js",
    "test": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File verify_sci_fi_catalog_page.ps1 && npm run test:migrate && npm run test:update-pipeline && npm run test:plex && npm run test:plex-sync && npm run test:state && npm run schema:check && npm run deploy:check && npm run server:check"
  },
